APP_NAME="RSUD Lubas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: MySQL 8 (production) atau MariaDB 10.6+
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rsud_lubas
DB_USERNAME=root
DB_PASSWORD=

# Cache, Session, Queue -> Redis
SESSION_DRIVER=redis
# Session timeout dalam menit (Requirement 14.5).
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_CONNECTION=default
# Aktifkan di production: cookie sesi hanya dikirim via HTTPS (Requirement 14.4).
SESSION_SECURE_COOKIE=false

CACHE_STORE=redis
CACHE_PREFIX=rsud_lubas

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_PREFIX=rsud_lubas:

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@rsud.local"
MAIL_FROM_NAME="${APP_NAME}"

# reCAPTCHA v3 (josiasmontag/laravel-recaptchav3)
RECAPTCHAV3_SITEKEY=
RECAPTCHAV3_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
