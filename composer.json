{
    "name": "rsud-lubas/website",
    "type": "project",
    "description": "Website RSUD Lubas - portal informasi publik dan panel admin.",
    "keywords": [
        "laravel",
        "rsud",
        "filament",
        "livewire"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "intervention/image": "^3.0",
        "josiasmontag/laravel-recaptchav3": "^1.0",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^3.0",
        "mews/purifier": "^3.4",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-backup": "^9.1",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-sitemap": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "giorgiosironi/eris": "^0.14",
        "larastan/larastan": "^2.9",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^2.34",
        "pestphp/pest-plugin-laravel": "^2.3",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": "@php artisan test",
        "test:unit": "@php artisan test --testsuite=Unit",
        "test:feature": "@php artisan test --testsuite=Feature",
        "test:property": "@php artisan test --testsuite=Property",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "11.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-pcntl": "8.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
